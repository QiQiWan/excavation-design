      "file": "00_general/G-00_drawing_index_general_notes.dxf",
      "fixedScale": "NTS",
      "scalePolicy": {},
      "trigger": {
        "op": "always"
      },
      "expansion": "single",
      "modelBinding": [
        "project",
        "standards",
        "drawing_register"
