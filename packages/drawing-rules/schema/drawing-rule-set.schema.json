{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pitguard.local/schema/drawing-rule-set-1.0.json",
  "title": "PitGuard Drawing Rule Set",
  "type": "object",
  "required": [
    "schemaVersion",
    "id",
    "name",
    "version",
    "parameters",
    "issuePolicy",
    "sheetRules"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0"
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "version": {
      "type": "string",
      "minLength": 1,
      "maxLength": 32
    },
    "preset": {
      "type": "string"
    },
    "parameters": {
      "type": "object",
      "properties": {
        "defaultPaperSize": {
          "enum": [
            "A0",
            "A1",
            "A2",
            "A3"
          ]
        },
        "usablePaperRatio": {
          "type": "number",
          "minimum": 0.55,
          "maximum": 0.95
        },
        "maximumSheetCount": {
          "type": "integer",
          "minimum": 10,
          "maximum": 500
        },
        "wallSheetsPerDrawing": {
          "type": "integer",
          "minimum": 1,
          "maximum": 12
        }
      },
      "additionalProperties": true
    },
    "objectiveWeights": {
      "type": "object",
      "additionalProperties": {
        "type": "number",
        "minimum": 0
      }
    },
    "issuePolicy": {
      "type": "object"
    },
    "sheetRules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "sheetNo",
          "title",
          "scope",
          "renderer",
          "file"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "enabled": {
            "type": "boolean"
          },
          "sheetNo": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "scope": {
            "enum": [
              "general",
              "rebar",
              "details"
            ]
          },
          "renderer": {
            "type": "string"
          },
          "file": {
            "type": "string"
          },
          "expansion": {
            "enum": [
              "single",
              "per_level",
              "per_wall"
            ]
          },
          "priority": {
            "type": "integer"
          },
          "required": {
            "type": "boolean"
          },
          "module": {
            "enum": [
              "general",
              "rebar",
              "details",
              "quality",
              "monitoring"
            ]
          },
          "scalePolicy": {
            "type": "object",
            "properties": {
              "kind": {
                "enum": [
                  "plan",
                  "section",
                  "detail"
                ]
              },
              "extent": {
                "type": "string"
              },
              "preferred": {
                "type": "integer"
              },
              "paperSize": {
                "enum": [
                  "A0",
                  "A1",
                  "A2",
                  "A3"
                ]
              },
              "orientation": {
                "enum": [
                  "landscape",
                  "portrait",
                  "auto"
                ]
              }
            },
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      }
    },
    "modules": {
      "type": "object",
      "properties": {
        "general": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "required": {
              "type": "boolean"
            }
          },
          "additionalProperties": false
        },
        "rebar": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "required": {
              "type": "boolean"
            }
          },
          "additionalProperties": false
        },
        "details": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "required": {
              "type": "boolean"
            }
          },
          "additionalProperties": false
        },
        "quality": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "required": {
              "type": "boolean"
            }
          },
          "additionalProperties": false
        },
        "monitoring": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "required": {
              "type": "boolean"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}